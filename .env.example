# Supabase Postgres — pooled connection (app) and direct connection (migrations).
# Find these in Supabase Dashboard → Connect. Replace [PASSWORD] with the database password.
DATABASE_URL="postgresql://postgres.npmtpnbxtqhovkivoaha:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.npmtpnbxtqhovkivoaha:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# NextAuth secret (generate with: openssl rand -base64 32)
AUTH_SECRET="change-me"

# Storage: "supabase" (default), "s3", or "local" (dev, writes to .uploads/)
STORAGE_PROVIDER="supabase"
SUPABASE_URL="https://npmtpnbxtqhovkivoaha.supabase.co"
# Secret (service-role) key — server-side only, never expose to the browser.
# Dashboard → Project Settings → API Keys.
SUPABASE_SECRET_KEY=""
SUPABASE_STORAGE_BUCKET="assets"

# Optional S3-compatible storage (if STORAGE_PROVIDER="s3")
S3_BUCKET=""
S3_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Google Maps (Geocoding, Static Maps, Places APIs)
GOOGLE_MAPS_API_KEY=""
