# Supabase Postgres — pooled connection (app) and direct connection (migrations).
# Find these in Supabase Dashboard → Connect. Replace [PASSWORD] with the database password.
DATABASE_URL="postgresql://postgres.npmtpnbxtqhovkivoaha:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.npmtpnbxtqhovkivoaha:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# NextAuth (Auth.js v5) — required. Generate with: openssl rand -base64 32
AUTH_SECRET="change-me"
# App URL including port (required when not running on default :3000)
AUTH_URL="http://localhost:3010"

# Storage: "supabase" (default), "s3", or "local" (dev, writes to .uploads/)
STORAGE_PROVIDER="supabase"
SUPABASE_URL="https://npmtpnbxtqhovkivoaha.supabase.co"
# Secret (service-role) key — server-side only, never expose to the browser.
# Dashboard → Project Settings → API Keys.
SUPABASE_SECRET_KEY=""
SUPABASE_STORAGE_BUCKET="assets"

# Optional S3-compatible storage (if STORAGE_PROVIDER="s3")
S3_BUCKET=""
S3_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Google Maps Platform — server-side only (Geocoding, Static Maps, Places).
# In Google Cloud Console: enable "Geocoding API", "Maps Static API",
# "Places API", and "Places API (New)" on the project, then create an API key
# with those APIs allowed. If the key has HTTP referrer or IP restrictions,
# allow your Vercel deployment egress IPs or use "None" for application
# restrictions during setup.
GOOGLE_MAPS_API_KEY=""
# Optional: separate key scoped to Places API (New) for Tenant Discovery.
# Falls back to GOOGLE_MAPS_API_KEY if unset.
GOOGLE_PLACES_API_KEY=""

# Brandfetch — used by the Tenant Logo Intelligence resolver chain. The
# client_id is sufficient for the free Logo Link CDN. Sign up at
# https://brandfetch.com/developers — without it, auto-logo lookup is
# disabled but manual upload still works.
BRANDFETCH_CLIENT_ID=""
# Optional: full Brand API key enables name-only lookup (Brand Search).
BRANDFETCH_API_KEY=""

# Demographics — US Census ACS 5-year (default). Set to "manual" to disable auto-fetch.
DEMOGRAPHICS_PROVIDER="census-acs"
# Required for Census auto-fetch (free): https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=""

# Optional site-plan vision analysis. If omitted, AI Analyze uses a safe fallback
# suggestion layer so the review workflow still works.
OPENAI_API_KEY=""
SITE_PLAN_AI_MODEL="gpt-4o-mini"

# PDF rendering (optional — auto-detected per environment)
# Local dev uses system Chrome. Vercel uses @sparticuz/chromium.
# CHROMIUM_EXECUTABLE_PATH=""  # override headless Chromium binary path
